# ----------------------
# Node / Build Artifacts
# ----------------------
node_modules/
client/node_modules/
server/node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
dist/
build/
.cache/
.tmp/
.vite/
vite.config.ts.timestamp*

# ----------------------
# Environment / Secrets
# ----------------------
.env
.env.*
*/.env
client/.env
server/.env
.env.local
.env.development.local
.env.production.local
.env.test.local
.envrc
*.secret
*.local
*.bak

# ----------------------
# Logs
# ----------------------
logs/
*.log
logs/**/*.log
debug.log
error.log
client/logs/
server/logs/

# ----------------------
# OS / System Files
# ----------------------
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini

